{
  "name": "liter-save",
  "version": "1.0.0",
  "private": true,
  "description": "React + Vite 기반 지역별 최저가 주유소 조회 서비스",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "generate:data": "node scripts/fetch-opinet.mjs",
    "opinet:test": "node scripts/opinet-local-check.mjs",
    "generate:report": "node scripts/generate-ai-report.mjs",
    "generate:oil": "node scripts/fetch-fred-oil.mjs",
    "generate:all": "npm run generate:data && npm run generate:oil && npm run generate:report",
    "quality:check": "node scripts/quality-check.mjs",
    "data:check": "node scripts/data-contract-check.mjs",
    "qa:check": "npm run quality:check && npm run data:check && npm run interaction:check && npm run render:check",
    "interaction:check": "node scripts/interaction-check.mjs",
    "render:check": "node scripts/render-check.mjs"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "vite": "^5.4.11",
    "tailwindcss": "^3.4.17",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.20"
  }
}
